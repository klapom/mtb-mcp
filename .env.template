# MTB MCP Server — Environment Variables
# Copy to .env and fill in your values: cp .env.template .env

# General
MTB_MCP_LOG_LEVEL=INFO
MTB_MCP_DATA_DIR=~/.mtb-mcp
MTB_MCP_DB_PATH=~/.mtb-mcp/mtb.db

# Home location (for default search center)
MTB_MCP_HOME_LAT=49.59
MTB_MCP_HOME_LON=11.00
MTB_MCP_DEFAULT_RADIUS_KM=30.0

# Strava API (https://strava.com/settings/api)
MTB_MCP_STRAVA_CLIENT_ID=
MTB_MCP_STRAVA_CLIENT_SECRET=
MTB_MCP_STRAVA_ACCESS_TOKEN=
MTB_MCP_STRAVA_REFRESH_TOKEN=

# Komoot (email + password for v007 API)
MTB_MCP_KOMOOT_EMAIL=
MTB_MCP_KOMOOT_PASSWORD=

# GPS-Tour.info (for GPX downloads)
MTB_MCP_GPSTOUR_USERNAME=
MTB_MCP_GPSTOUR_PASSWORD=

# OpenRouteService (https://openrouteservice.org/)
MTB_MCP_ORS_API_KEY=

# BRouter (self-hosted via Docker)
MTB_MCP_BROUTER_URL=http://localhost:17777

# SearXNG (self-hosted via Docker)
MTB_MCP_SEARXNG_URL=http://localhost:17888

# Bosch eBike Cloud (future)
MTB_MCP_BOSCH_CLIENT_ID=
MTB_MCP_BOSCH_CLIENT_SECRET=

# Wahoo Fitness API (future)
MTB_MCP_WAHOO_CLIENT_ID=
MTB_MCP_WAHOO_CLIENT_SECRET=
